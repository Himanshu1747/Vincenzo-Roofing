</header>
<div class="margin-top"></div>
<div class="custom-cursor" aria-hidden="true"></div>

<style>
	.mainnav-links {
		display: flex;
		align-items: center;
		gap: 40px;
		width: 100%;
	}
	.grid-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 30px;
		width: 100%;
	}

	.custom-header {
		position: fixed;
		width: 100%;
		top: 0;
		z-index: 99;
	}

	.lastbuttons a {
		background: var(--color-blue);
		color: var(--color-white);
		padding: 10px 20px;
		border-radius: 109px;
	}
	.lastbuttons a:hover {
		background: var(--color-black);
		color: var(--color-white) !important;
	}
	.mainnav-links li a {
		font-size: 16px;
		font-weight: 600;
		line-height: normal;
	}
	.mainnav-links li a:hover {
		color: var(--color-blue);
	}
	.menu-item-has-children {
		position: relative;
		padding-right: 20px;
	}
	.menu-item-has-children::after {
		position: absolute;
		top: 12px;
		right: 0;
		width: 8px;
		height: 8px;
		border-right: 2px solid var(--color-black);
		border-bottom: 2px solid var(--color-black);
		transform: translateY(-50%) rotate(45deg);
		content: "";
		transition: 0.3s ease-in;
		cursor: pointer;
	}
	ul.sub-menu {
		position: absolute;
		top: 100%;
		width: 320px;
		left: -8px;
		padding-top: 28px;
		display: none;
		animation:slideup 0.3s linear;

	}
	@keyframes slideup{
		0%{
				clip-path: polygon(0 100%, 100% 100%, 100% 100%, 0% 100%);

		}
		100%{
			clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 100%);

		}
	}

	ul.sub-menu li {
		padding: 10px 15px;
		border-bottom: 1px solid var(--color-D3D3D3);
		background: #fffc;
		backdrop-filter: blur(3px);
		border-bottom: 1px solid rgba(196, 196, 196, 0.8);
	}
	ul.sub-menu li a {
		display: block;
		color: var(--color-black);
	}
	.logo-main {
		background: var(--color-white);
		border-radius: 5px;
	}
	.top-header {
		background: var(--color-blue);
		color: var(--color-white);
	}
	.grid-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 30px;
	}
	.bottom-header {
		padding: 10px 0px;
		background: var(--color-white);
		/* -webkit-backdrop-filter: saturate(160%) blur(14px);
		backdrop-filter: saturate(160%) blur(14px);
		box-shadow: 0 6px 24px #0a0a2812; */
		border-bottom: 1px solid rgba(20, 20, 50, 0.06);
	}

	.top-header p {
		font-size: 14px;
		font-weight: 400;
		padding: 0;
		margin: 0;
	}
	.top-header {
		padding: 5px 0px;
	}
	.margin-top {
		margin-top: 110px;
	}
	.custom-cursor {
		position: fixed;
		top: 0;
		left: 0;
		width: 10px;
		height: 10px;
		background: var(--color-blue);
		border-radius: 50%;
		pointer-events: none;
		z-index: 9999;
		transform: translate(-50%, -50%);
		transition: transform 0.15s ease-out;
	}
	.menu-icon {
		display: none;
	}
	.bars {
		width: 40px;
		cursor: pointer;
	}

	.bars .line {
		fill: none;
		stroke: #000;
		stroke-width: 4;
		stroke-linecap: square;
		transition:
			stroke-dasharray 400ms,
			stroke-dashoffset 1s;
	}

	.bars .line.top {
		stroke-dasharray: 40 172;
	}

	.bars .line.middle {
		stroke-dasharray: 40 111;
	}

	.bars .line.bottom {
		stroke-dasharray: 40 172;
	}

	.bars.active .top {
		stroke-dashoffset: -132px;
	}

	.bars.active .middle {
		stroke-dashoffset: -71px;
	}

	.bars.active .bottom {
		stroke-dashoffset: -132px;
	}

	/* MENU ICON ANIMATED END */
	@media (min-width: 1200px) {
		.menu-item-has-children:hover ul.sub-menu {
			display: block;
		}
	}
	@media (max-width: 1600px) {
		.mainnav-links {
			gap: 30px;
		}
		.mainnav-links li a {
			font-size: 15px;
		}
	}
	@media (max-width: 1400px) {
		.mainnav-links {
			gap: 20px;
		}
		.logo-main {
			max-width: 100px;
		}
		.mainnav-links li a {
			font-size: 14px;
		}

		.top-header p {
			font-size: 11px;
		}
		.margin-top {
			margin-top: 87px;
		}
		ul.sub-menu {
			width: 230px;
			padding-top: 19px;
		}
	}
	@media (max-width: 1199px) {
		.grid-header {
			flex-direction: column;
			align-items: start;
		}

		.mainnav-links {
			gap: 15px;
			flex-direction: column;
			align-items: start;
			gap: 20px;
		}
		.menu-icon {
			display: block;
		}
		.mobile-grids {
			display: flex;
			align-items: center;
			justify-content: space-between;
			width: 100%;
		}
		.main-navlists {
			width: 100%;
			height: 60vh;
			overflow-y: scroll;
			display: none;
		}
		ul.mainnav-links li {
			width: 100%;
		}
		ul.sub-menu {
			position: static;
			width: 100%;
			padding: 0;
		}
		ul.sub-menu li {
			padding: 10px 5px;
		}
		.menu-item-has-children:after {
			right: 20px;
		}
	}
	@media (max-width: 767px) {
		.top-header {
			display: none;
		}
		.margin-top {
			margin-top: 61px;
		}
	}
</style>

<script is:inline>
	const cursor = document.querySelector(".custom-cursor");
	if (cursor && window.innerWidth > 1200) {
		let mouseX = 0,
			mouseY = 0;
		let posX = 0,
			posY = 0;
		let isMoving = false;

		window.addEventListener(
			"mousemove",
			(e) => {
				mouseX = e.clientX;
				mouseY = e.clientY;

				// Only start the loop if it is asleep
				if (!isMoving) {
					isMoving = true;
					requestAnimationFrame(animateCursor);
				}
			},
			{ passive: true },
		);

		const animateCursor = () => {
			const distX = mouseX - posX;
			const distY = mouseY - posY;

			// If distance is significant, animate. Otherwise, go to sleep.
			if (Math.abs(distX) > 0.1 || Math.abs(distY) > 0.1) {
				posX += distX * 0.15;
				posY += distY * 0.15;
				cursor.style.transform = `translate3d(${posX}px, ${posY}px, 0)`;
				requestAnimationFrame(animateCursor);
			} else {
				isMoving = false; // Sleep state to save CPU
			}
		};
	} else if (cursor) {
		cursor.style.display = "none";
	}
</script>
<script is:inline>
	// Using jQuery as requested
	function setupNavigation() {
		// 1. Unbind then bind for the main menu icon
		$(".menu-icon")
			.off("click")
			.on("click", function () {
				$(this).find(".bars").toggleClass("active");
				$(".main-navlists").slideToggle();
			});

		// 2. Add .off("click") here to prevent multiple bindings on page transitions!
		$(".menu-item-has-children")
			.off("click")
			.on("click", function (e) {
				e.stopPropagation();

				// Optional: If clicking this should ONLY open the menu and not act as a link
				// e.preventDefault();

				$(this)
					.toggleClass("active")
					.children(".sub-menu")
					.slideToggle();
			});
	}

	document.addEventListener("DOMContentLoaded", setupNavigation);
	document.addEventListener("astro:page-load", setupNavigation);
</script>
