---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
---

<!-- Top strip -->
<div class="top-strip">
	<div class="container">
		<div class="left">
			Licensed &amp; Insured · Serving all of New Hampshire
		</div>
		<div>
			<span class="pulse"></span>24/7 Emergency Line: <a
				href="tel:+16035550199">(603) 555-0199</a>
		</div>
	</div>
</div>

<!-- Header -->
<header id="siteHeader">
	<div class="nav-wrap">
		<a href="#top" class="logo" aria-label="Vincenzo's Roofing LLC home">
			<svg
				class="logo-mark"
				viewBox="0 0 44 44"
				fill="none"
				xmlns="http://www.w3.org/2000/svg"
			>
				<path d="M22 3L41 24H34V41H10V24H3L22 3Z" fill="#111111"></path>
				<path d="M22 11L33 23H29V35H15V23H11L22 11Z" fill="#0D47A1"
				></path>
				<path d="M22 19L27 24.5H25V30H19V24.5H17L22 19Z" fill="#FFFFFF"
				></path>
			</svg>
			<span class="logo-text"
				>Vincenzo's Roofing<span>New Hampshire</span></span
			>
		</a>
		<nav class="primary" aria-label="Primary">
			<a href="/about-us/">About Us</a>
			<a href="/roofing-services/">Services</a>
			<a href="/service-areas/">Service Areas</a>
			<a href="/gallery/">Gallery</a>
			<a href="/reviews/">Reviews</a>
			<a href="/faq/">FAQ</a>
		</nav>
		<div class="header-ctas">
			<a href="tel:+16035550199" class="header-phone">
				<svg
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.9"
					><path
						d="M22 16.9v3a2 2 0 01-2.2 2 19.8 19.8 0 01-8.6-3 19.5 19.5 0 01-6-6 19.8 19.8 0 01-3-8.7A2 2 0 014.1 2h3a2 2 0 012 1.7c.1.9.3 1.8.6 2.7a2 2 0 01-.5 2.1L8 9.9a16 16 0 006 6l1.4-1.4a2 2 0 012.1-.5c.9.3 1.8.5 2.7.6a2 2 0 011.8 2.3z"
					></path></svg
				>
				<span>(603) 555-0199</span>
			</a>
			<a href="#contact" class="btn btn-blue">Free Estimate</a>
			<button
				class="menu-toggle"
				id="menuToggle"
				aria-label="Open menu"
				aria-expanded="false"><span></span></button
			>
		</div>
	</div>
</header>

<div class="mobile-panel" id="mobilePanel">
	<a href="/about-us/" class="mp-link">About Us</a>
	<a href="/roofing-services/" class="mp-link">Services</a>
	<a href="/service-areas/" class="mp-link">Service Areas</a>
	<a href="/gallery/" class="mp-link">Gallery</a>
	<a href="/reviews/" class="mp-link">Reviews</a>
	<a href="/financing/" class="mp-link">Financing</a>
	<a href="/blog/" class="mp-link">Blog</a>
	<a href="/contact/" class="mp-link">Contact</a>
	<div class="mp-ctas">
		<a href="tel:+16035550199" class="btn btn-ghost-w"
			>Call (603) 555-0199</a
		>
		<a href="#contact" class="btn btn-blue">Get a Free Estimate</a>
	</div>
</div>
