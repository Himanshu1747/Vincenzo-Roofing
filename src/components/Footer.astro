<script is:inline>
/* Header shadow on scroll */
const hdr = document.getElementById('siteHeader');
addEventListener('scroll', () => hdr.classList.toggle('scrolled', scrollY > 8), {passive:true});

/* Mobile panel */
const btn = document.getElementById('menuToggle');
const panel = document.getElementById('mobilePanel');
btn.addEventListener('click', () => {
  const isOpen = panel.classList.toggle('open');
  btn.classList.toggle('active', isOpen);
  btn.setAttribute('aria-expanded', isOpen);
  document.body.style.overflow = isOpen ? 'hidden' : '';
});
panel.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
  panel.classList.remove('open'); btn.classList.remove('active');
  btn.setAttribute('aria-expanded','false'); document.body.style.overflow = '';
}));

/* Duplicate marquee content for seamless loop */
const mq = document.getElementById('marquee');
mq.innerHTML += mq.innerHTML;

/* FAQ accordion */
document.querySelectorAll('.faq-item').forEach(item => {
  item.querySelector('.faq-q').addEventListener('click', () => {
    const wasOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
    if(!wasOpen) item.classList.add('open');
  });
});

/* Scroll reveal */
const io = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('reveal-in'); io.unobserve(e.target); } });
}, {threshold:0.1, rootMargin:'0px 0px -50px 0px'});
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

/* Animated counter */
const counter = document.querySelector('[data-count]');
if(counter){
  const target = +counter.dataset.count;
  const cio = new IntersectionObserver(entries => {
    if(!entries[0].isIntersecting) return;
    cio.disconnect();
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if(reduced){ counter.textContent = target.toLocaleString(); return; }
    const t0 = performance.now(), dur = 1400;
    (function tick(t){
      const p = Math.min((t - t0) / dur, 1);
      counter.textContent = Math.round(target * (1 - Math.pow(1 - p, 3))).toLocaleString();
      if(p < 1) requestAnimationFrame(tick);
    })(t0);
  }, {threshold:0.4});
  cio.observe(counter);
}
</script>