---
const today = new Date();
---

<footer class="custom-footer">
    <div class="ctafooter">
        <div class="container">
            <div class="cta-data">
                <h6 class="fs-70">Get Your Roofing Project Started Today!</h6>
                <div class="universal-button">
                    <a href="#" class="button-links golden" title="GET A QUOTE"
                        >GET A QUOTE</a
                    >
                </div>
            </div>
        </div>
    </div>

    <div class="other-datafooter">
        <div class="container">
            <div class="grid-footer">
                <div class="logo-container">
                    <div class="grid-ceo">
                        <div class="textwidget custom-html-widget">
                            <div class="ceo-say">
                                <div class="footer-logo">
                                    <img
                                        src="/logo.webp"
                                        alt=""
                                        width="200"
                                        height="78"
                                    />
                                </div>
                                <p>
                                    Lorem, ipsum dolor sit amet consectetur
                                    adipisicing elit. Tenetur minima porro sit
                                    nulla? Laborum, eaque!
                                </p>
                                <p>
                                    <a href="#"
                                        ><strong>Call:</strong>1234567890</a
                                    >
                                </p>
                                <p>
                                    <a href="#"
                                        ><strong>Mail:</strong>text@gmail.com</a
                                    >
                                </p>
                            </div>
                            <ul class="social-mediafooter">
                                <li>
                                    <a href="#"
                                        ><img
                                            src="/facebook.png"
                                            height="20"
                                            width="11"
                                            loading="lazy"
                                            alt=""
                                        /></a
                                    >
                                </li>
                                <li>
                                    <a href="#"
                                        ><img
                                            src="/linkdin.png"
                                            height="18"
                                            width="20"
                                            loading="lazy"
                                            alt=""
                                        /></a
                                    >
                                </li>
                                <li>
                                    <a href="#"
                                        ><img
                                            src="/instagramf.png"
                                            height="20"
                                            width="20"
                                            loading="lazy"
                                            alt=""
                                        /></a
                                    >
                                </li>
                                <li>
                                    <a href="#"
                                        ><img
                                            src="/youtube.png"
                                            height="16"
                                            width="20"
                                            loading="lazy"
                                            alt=""
                                        /></a
                                    >
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="navlinks-footer">
                    <h6 class="fs-30">Quick Links</h6>
                    <ul class="footer-links">
                        <li>
                            <a href="#" target="_self" title="About"> About </a>
                        </li>
                        <li>
                            <a href="#" target="_self" title="Services">
                                Services
                            </a>
                        </li>
                        <li>
                            <a href="#" target="_self" title="Technology">
                                Locations
                            </a>
                        </li>
                        <li>
                            <a href="#" target="_self" title="Marketing">
                                Projects
                            </a>
                        </li>
                        <li>
                            <a href="#" target="_self" title="Our Work">
                                Blog
                            </a>
                        </li>
                        <li>
                            <a href="#" target="_self" title="Contact">
                                Contact
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="all-location">
                    <div class="address-footer">
                            <iframe
                                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d52816169.558200695!2d-161.49265223136007!3d36.102185713814805!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x54eab584e432360b%3A0x1c3bb99243deb742!2sUnited%20States!5e0!3m2!1sen!2sin!4v1784379826947!5m2!1sen!2sin"
                                width="600"
                                height="300"
                                style="border:0;"
                                allowfullscreen=""
                                loading="lazy"
                                referrerpolicy="strict-origin-when-cross-origin"
                            ></iframe>
                        </div>
                </div>
            </div>

            <div>
                <div class="textwidget custom-html-widget">
                    <div class="copyrights-holders">
                        <div class="container">
                            <div class="grid-copyrights">
                                <div class="data-herecopyrights">
                                    <p>
                                        Copyright Vincenzo Roofing © 2026. All
                                        rights reserved.
                                    </p>
                                </div>
                                <div class="logo-only">
                                    <img
                                        src="/logo.webp"
                                        alt=""
                                        width="130"
                                        height="50"
                                        loading="lazy"
                                    />
                                </div>
                                <div class="policy">
                                    <p>
                                        <a href="#">Refund Policy</a> | <a
                                            href="#">Privacy Policy</a
                                        > | <a href="#">Sitemap</a>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</footer>

<style is:global>
    .grid-footer {
        display: flex;
        gap: 50px;
        justify-content: space-between;
        padding-top: 80px;
    }

    .logo-container {
        max-width: 500px;
        width: 100%;
    }

    .custom-footer p,
    .navlinks-footer ul li a {
        font-size: 18px;
        font-weight: 400;
        color: var(--color-black);
    }
    .navlinks-footer ul li a:hover{
        color: var(--color-blue);
    }

    .all-location,
    .all-location .textwidget {
        max-width: 500px;
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    footer.custom-footer {
        background: var(--color-white);
    }

    .ctafooter {
        background: var(--color-blue);
        color: var(--color-white);
        border-radius: 0px 0px 50px 50px;
        padding: 50px 0px;
    }

    .logo-only {
        max-width: 230px;
        width: 100%;
    }

    .navlinks-footer ul {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    footer.custom-footer .universal-anchor {
        padding-top: 20px;
    }

    .grid-copyrights {
        display: flex;
        justify-content: space-between;
        gap: 30px;
    }

    .copyrights-holders {
        border-top: 1px solid #000;
        margin-top: 40px;
        padding: 30px 0px 30px 0px;
    }

    .cta-data .fs-100 {
        padding-bottom: 20px;
    }

    .ceo-image {
        max-width: 200px;
        overflow: hidden;
        border-radius: 20px;
        height: 200px;
    }

    .ceo-image img {
        height: 100%;
        width: 100%;
        object-fit: cover;
        object-position: center;
    }

    .profile-grids {
        display: flex;
        align-items: center;
        gap: 30px;
        padding-bottom: 10px;
    }

    .ceo-name {
        max-width: fit-content;
        width: 100%;
    }

    .profile-grids .fs-30 {
        font-weight: 700;
        padding-bottom: 5px;
    }
    .ctafooter {
        position: relative;
        z-index: 2;
    }

    .other-datafooter {
        /* position: sticky; */
        bottom: 0;
        left: 0;
        width: 100%;
        z-index: 1;
    }
    .cta-data .universal-button {
        padding-top: 10px;
    }
    .cta-data {
        text-align: center;
    }

    ul.social-mediafooter {
        display: flex;
        align-items: center;
        gap: 20px;
        padding-top: 30px;
    }

    ul.social-mediafooter li a {
        height: 40px;
        width: 40px;
        /* background: red; */
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        padding: 9px;
        background: rgb(69 65 241 / 100%);
        /* border-radius: 16px; */
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
        backdrop-filter: blur(5px);
        -webkit-backdrop-filter: blur(5px);
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .badge-holders {
        /* background:var(--color-blue); */
        background: linear-gradient(90deg, #4541f1, #4541f1ab);
        color: var(--color-white);
        display: flex;
        align-items: center;
        gap: 8px;
        border-radius: 10px;
        padding: 5px 20px 5px 10px;
        max-width: fit-content;
        width: 100%;
        margin-bottom: 15px;
    }

    .badge-holders .fs-20 {
        padding-bottom: 0;
    }

    .badge-holders .fs-20 {
        font-size: 16px;
        font-weight: 400 !important;
        line-height: 136%;
    }

    .navlinks-footer {
        max-width: fit-content;
        width: 100%;
    }

    .footer-logo {
        max-width: 200px;
        width: 100%;
        margin-bottom: 20px;
    }
    .all-location iframe {
        width: 100%;
        border-radius: 10px;
    }
    @media (max-width: 1600px) {
        .ceo-image {
            max-width: 160px;
            height: 160px;
        }
        .custom-footer p,
        .navlinks-footer ul li a {
            font-size: 16px;
        }
        .copyrights-holders {
            margin-top: 40px;
            padding: 15px 0px;
        }
        .logo-only {
            max-width: 195px;
        }
        .grid-footer {
            padding-top: 60px;
        }
    }
    @media (max-width: 1400px) {
        .grid-ceo {
            max-width: 368px;
            width: 100%;
        }
        .all-location,
        .all-location .textwidget {
            max-width: 422px;
            gap: 25px;
        }
        .badge-holders .fs-20 {
            font-size: 14px;
            font-weight: 400 !important;
        }
        .custom-footer p,
        .navlinks-footer ul li a {
            font-size: 15px;
        }
        .logo-container {
            max-width: fit-content;
        }
    }

    @media (max-width: 1199px) {
        .grid-footer {
            padding-top: 40px;
        }

        .profile-grids {
            flex-direction: column;
            align-items: start;
        }
        .ceo-name {
            text-align: start;
        }
    }
    @media (max-width: 991px) {
        .ctafooter {
            border-radius: 0px 0px 30px 30px;
            padding: 40px 0px;
        }

        .ctafooter,
        .other-datafooter {
            position: static;
        }
    }
    @media (max-width: 767px) {
        .grid-footer {
            flex-wrap: wrap;
            justify-content: start;
        }
        .grid-ceo {
            max-width: 300px;
        }
        .grid-copyrights {
            gap: 20px;
            flex-direction: column;
            justify-content: center;
            text-align: center;
        }
        .logo-only {
            display: none;
        }
.all-location {
    max-width: 100%;
    width: 100%;
}
    }
</style>
