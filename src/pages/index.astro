---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Testimonials from "../components/Testimonials.astro";
import Faqcompo from "../components/Faqcompo.astro";
import Contactform from "../components/Contactform.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { queryWordPress } from "../lib/wordpress";
import Contact from "./contact.astro";

const HOMEPAGE = `
query homepagedata {
  page(id: "/", idType: URI) {
    featuredImage {
      node {
        mediaItemUrl
        altText
      }
    }
    title
    content
    homepage {
      imageWaranty
      imageReview
      slidingText
      whatWeDoContent
      whyChooseContent
      whyChooseGrid {
        iconImage {
          node {
            mediaItemUrl
          }
        }
        gridData
      }
      whyVincenzoContent
      whyVincenzoList {
        vincenzoIcon {
          node {
            mediaItemUrl
          }
        }
        vincenzoDetails
      }
      whyVincenzoImage {
        node {
          mediaItemUrl
        }
      }
      imageContent
      howWorkContent
      howWorkGrid {
        contentGridSteps
      }
      allTimeAvaialbelData
      faqHomeContents
      finalCtaData
      serviceAreaContent
      allAreas{
        areaPageLinks{
          url
        }
        areaName
      }
      exploreAllAreas{
        url
        title
      }
    }
  }
  services(first: 5) {
    nodes {
      slug
      title
      excerpt
      content
    }
  }
}
`;

const pagedata = await queryWordPress(HOMEPAGE);
const responsedata = pagedata?.page || {};
const servicesData = pagedata?.services?.nodes || [];
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body>
        <Header />
        <main id="top">
            <!-- Hero -->
            <section class="hero">
                <div class="hero-grid-tex" aria-hidden="true"></div>
                <div class="container hero-inner">
                    <div class="hero-copy">
                        <Fragment set:html={responsedata?.content || "error"} />
                    </div>

                    <div class="hero-visual">
                        <div class="hero-card">
                            <img
                                src={responsedata?.featuredImage?.node
                                    ?.mediaItemUrl || "error"}
                                alt="Vincenzo’s Roofing"
                                width="625"
                                height="473"
                                fetchpriority="high"
                            />
                        </div>
                        <div class="hero-float warranty">
                            <div class="ic">
                                <svg
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><path
                                        d="M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-4z"
                                    ></path><path d="M9 12l2 2 4-4"></path></svg
                                >
                            </div>
                            <div
                                class="warnaty-box"
                                set:html={responsedata?.homepage
                                    ?.imageWaranty || "error"}
                            >
                            </div>
                        </div>
                        <div
                            class="hero-float review"
                            set:html={responsedata?.homepage?.imageReview ||
                                "error"}
                        >
                        </div>
                    </div>
                </div>
            </section>

            <!-- Marquee trust bar -->

            <div class="marquee-wrap" aria-hidden="true">
                <div class="marquee" id="marquee">
                    <p class="marquee-content">
                        {responsedata?.homepage?.slidingText || "error"}
                    </p>
                </div>
            </div>

            <!-- Services -->
            <section class="section svc-section" id="services">
                <div class="container">
                    <div
                        class="sec-header"
                        set:html={responsedata?.homepage?.whatWeDoContent ||
                            "error"}
                    />
                    <div class="svc-grid">
                        {
                            servicesData.map((service, index) => (
                                <div class={`svc-card ${index < 2 ? 'feature reveal' : 'reveal'}`}>
                                    <span class="svc-num">{String(index + 1).padStart(2, '0')}</span>
                                    <div class="svc-icon">
                                        <svg
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="1.8"
                                        >
                                            <path d="M3 11l9-7 9 7"></path>
                                            <path d="M5 10v10h14V10"></path>
                                        </svg>
                                    </div>
                                    <h3 set:html={service.title} />
                                    <div set:html={service.excerpt || service.content} />
                                    <a class="svc-arrow" href={`/service/${service.slug}`}
                                        >Explore Now</a
                                    >
                                </div>
                            ))
                        }
                    </div>
                </div>
            </section>

            <!-- Why Choose Us (Unique Layout) -->
            <section class="section" id="why-choose-us">
                <div class="container">
                    <div
                        class="sec-header"
                        set:html={responsedata?.homepage?.whyChooseContent ||
                            "error"}
                    />

                    <div class="wcu-grid">
                        {
                            responsedata?.homepage?.whyChooseGrid.map(
                                (chooseitems) => (
                                    <div class="wcu-card reveal">
                                        <div class="wcu-icon">
                                            <img
                                                src={
                                                    chooseitems?.iconImage?.node
                                                        ?.mediaItemUrl ||
                                                    "error"
                                                }
                                                alt="icon-image"
                                                width="24"
                                                height="24"
                                                loading="lazy"
                                            />
                                        </div>
                                        <Fragment
                                            set:html={
                                                chooseitems?.gridData || "error"
                                            }
                                        />
                                    </div>
                                ),
                            )
                        }
                    </div>
                </div>
            </section>

            <section class="section" id="why">
                <div class="container why-wrap">
                    <div class="why-visual reveal">
                        <div class="frame">
                            <img
                                src={responsedata?.homepage?.whyVincenzoImage
                                    ?.node?.mediaItemUrl || "error"}
                                alt="Why Vincenzo’s"
                                loading="lazy"
                                width="617"
                                height="462"
                            />
                        </div>
                        <div
                            class="why-chip"
                            set:html={responsedata?.homepage?.imageContent ||
                                "error"}
                        />
                    </div>
                    <div>
                        <Fragment
                            set:html={responsedata?.homepage
                                ?.whyVincenzoContent || "error"}
                        />
                        <div class="why-list">
                            {
                                responsedata?.homepage?.whyVincenzoList.map(
                                    (vincenzoitems) => (
                                        <div class="why-item reveal">
                                            <div class="why-icon">
                                                <img
                                                    src={
                                                        vincenzoitems
                                                            ?.vincenzoIcon?.node
                                                            ?.mediaItemUrl ||
                                                        "error"
                                                    }
                                                    alt="icon"
                                                    height="20"
                                                    width="20"
                                                    loading="lazy"
                                                />
                                            </div>
                                            <div>
                                                <Fragment
                                                    set:html={
                                                        vincenzoitems?.vincenzoDetails ||
                                                        "error"
                                                    }
                                                />
                                            </div>
                                        </div>
                                    ),
                                )
                            }
                        </div>
                    </div>
                </div>
            </section>

            <!-- Process -->
            <section class="section process" id="process">
                <div class="container">
                    <div
                        class="sec-header"
                        set:html={responsedata?.homepage?.whyVincenzoContent ||
                            "error"}
                    />
                    <div class="process-grid">
                        {
                            responsedata?.homepage?.howWorkGrid?.map(
                                (whyitems, index) => (
                                    <div class="p-step reveal">
                                        <span class="p-num">
                                            Step{" "}
                                            {String(index + 1).padStart(2, "0")}
                                        </span>
                                        <Fragment
                                            set:html={
                                                whyitems?.contentGridSteps ||
                                                "error"
                                            }
                                        />
                                    </div>
                                ),
                            )
                        }
                    </div>
                </div>
            </section>

            <!-- Gallery -->
            <section class="section" id="gallery">
                <div class="container">
                    <div class="sec-header">
                        <span class="eyebrow">Recent Work</span>
                        <h2 class="sec-head">
                            Real roofs, <span class="accent"
                                >across the state.</span
                            >
                        </h2>
                    </div>
                    <div class="ba-grid">
                        <div class="ba-card reveal">
                            <div class="ba-media">
                                <img src="/image-5.png" alt="" />
                            </div>
                            <div class="ba-body">
                                <h4>Asphalt Shingle Replacement</h4><p>
                                    Manchester, NH — full tear-off and re-roof
                                </p>
                            </div>
                        </div>
                        <div class="ba-card reveal">
                            <div class="ba-media">
                                <img src="/image-4.png" alt="" />
                            </div>
                            <div class="ba-body">
                                <h4>Storm Damage Restoration</h4><p>
                                    Nashua, NH — wind damage, insurance-assisted
                                </p>
                            </div>
                        </div>
                        <div class="ba-card reveal">
                            <div class="ba-media">
                                <img src="/image-3.png" alt="" />
                            </div>
                            <div class="ba-body">
                                <h4>Standing-Seam Metal Roof</h4><p>
                                    Portsmouth, NH — commercial install
                                </p>
                            </div>
                        </div>
                    </div>
                    <p class="note">
                        Illustrative placeholders — swap in real project
                        photography before launch.
                    </p>
                </div>
            </section>

            <!-- Testimonials -->
            <section class="section testi">
                <div class="container">
                    <div class="sec-header">
                        <span class="eyebrow">Reviews</span>
                        <h2 class="sec-head">What NH homeowners say.</h2>
                        <a class="svc-arrow" href="/gutter-installation/"
                            >View All testimonials</a
                        >
                    </div>
                    <Testimonials />
                    <p class="note">
                        Placeholder testimonials for layout — replace with
                        verified Google reviews before launch.
                    </p>
                </div>
            </section>

            <section class="emergency">
                <div
                    class="container"
                    set:html={responsedata?.homepage?.allTimeAvaialbelData ||
                        "error"}
                />
            </section>

            <!-- Areas -->
            <section class="section" id="areas" style="background: #F6F7F9;">
                <div class="container areas-wrap">
                    <div>
                        <Fragment
                            set:html={responsedata?.homepage
                                ?.serviceAreaContent || "error"}
                        />

                        <div class="area-chips">
                            {
                                responsedata?.homepage?.allAreas?.map(
                                    (locationitems) => (
                                        <a
                                            class="area-chip"
                                            title={locationitems?.areaName || "error"}
                                            href={locationitems?.areaPageLinks?.url || "error"}
                                        >
                                        {locationitems?.areaName || "error"}
                                        </a>
                                    ),
                                )
                            }
                        </div>
                        <a
                            href={responsedata?.homepage?.exploreAllAreas?.url || "error"}
                            class="btn btn-blue"
                            style="margin-top: 25px;">{responsedata?.homepage?.exploreAllAreas?.title || "error"}</a
                        >
                    </div>
                    <div class="map-frame reveal">
                        <svg
                            viewBox="0 0 520 430"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <rect width="520" height="430" fill="#071F45"
                            ></rect>
                            <path
                                d="M160 30 L355 62 L335 168 L378 232 L346 360 L188 392 L126 274 L94 126 Z"
                                fill="#0E2B5B"
                                stroke="#0D47A1"
                                stroke-width="2.5"></path>
                            <g fill="#4A7FD4"
                                ><circle cx="210" cy="190" r="6"
                                ></circle><circle cx="252" cy="232" r="6"
                                ></circle><circle cx="190" cy="105" r="6"
                                ></circle><circle cx="272" cy="315" r="6"
                                ></circle><circle cx="318" cy="210" r="6"
                                ></circle></g
                            >
                            <g
                                fill="none"
                                stroke="#4A7FD4"
                                stroke-opacity="0.35"
                                stroke-width="1.4"
                            >
                                <circle cx="210" cy="190" r="14"
                                ></circle><circle cx="252" cy="232" r="14"
                                ></circle><circle cx="190" cy="105" r="14"
                                ></circle><circle cx="272" cy="315" r="14"
                                ></circle><circle cx="318" cy="210" r="14"
                                ></circle>
                            </g>
                            <text
                                x="260"
                                y="416"
                                fill="#7A8FB4"
                                font-family="Montserrat,sans-serif"
                                font-weight="600"
                                font-size="11"
                                text-anchor="middle"
                                letter-spacing="2"
                                >SERVING ALL OF NEW HAMPSHIRE</text
                            >
                        </svg>
                    </div>
                </div>
            </section>

            <!-- FAQ -->
            <section class="section" id="faq">
                <div class="container">
                    <div
                        class="sec-header"
                        style="text-align:center;"
                        set:html={responsedata?.homepage?.faqHomeContents ||
                            "error"}
                    />
                    <Faqcompo />
                </div>
            </section>

            <!-- CTA band -->
            <section class="cta-band">
                <div
                    class="cta-inner"
                    set:html={responsedata?.homepage?.finalCtaData || "error"}
                />
            </section>

            <!-- Contact -->
            <Contactform />
        </main>

        <Footer />
        <script>
            document.addEventListener("DOMContentLoaded", () => {
                const marquee = document.getElementById("marquee");
                const marqueeWrap = document.querySelector(".marquee-wrap");

                if (!marquee || !marqueeWrap) return;

                const content = marquee.querySelector(".marquee-content");

                // Clone the p tag multiple times to ensure it covers wide screens
                marquee.appendChild(content.cloneNode(true));
                marquee.appendChild(content.cloneNode(true));
                marquee.appendChild(content.cloneNode(true));

                let xPos = 0;
                // TWEAK THIS NUMBER TO CHANGE SPEED (higher = faster)
                const speed = 0.5;
                let isHovered = false;

                // Pause on hover
                marqueeWrap.addEventListener(
                    "mouseenter",
                    () => (isHovered = true),
                );
                marqueeWrap.addEventListener(
                    "mouseleave",
                    () => (isHovered = false),
                );

                function animate() {
                    if (!isHovered) {
                        // Get the width of ONE original p tag
                        const contentWidth = content.offsetWidth;

                        xPos -= speed;

                        // Instantly snap back to 0 when one full p tag has scrolled by
                        if (Math.abs(xPos) >= contentWidth) {
                            xPos = 0;
                        }

                        marquee.style.transform = `translate3d(${xPos}px, 0, 0)`;
                    }

                    requestAnimationFrame(animate);
                }

                animate();
            });
        </script>
    </body>
</html>