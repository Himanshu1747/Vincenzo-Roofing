---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Testimonials from "../components/Testimonials.astro";
import Faqcompo from "../components/Faqcompo.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
		/>
	</head>
	<body>
		<Header />
		<main id="top">
			<!-- Hero -->
			<section class="hero">
				<div class="hero-grid-tex" aria-hidden="true"></div>
				<div class="container hero-inner">
					<div class="hero-copy">
						<div class="hero-kicker">
							<span class="chip">NH</span> Residential &amp; Commercial
							Roofing
						</div>
						<h1>
							A roof built for <em>every season</em> New Hampshire throws
							at it.
						</h1>
						<p class="lede">
							Vincenzo's Roofing installs, repairs, and replaces
							roofs across the state — backed by a 25-year written
							workmanship warranty and same-day storm response.
						</p>
						<div class="hero-ctas">
							<a href="#contact" class="btn btn-blue"
								>Get a Free Estimate
								<svg
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2.2"
									><path d="M5 12h14M13 6l6 6-6 6"
									></path></svg
								>
							</a>
							<a href="tel:+16035550199" class="btn btn-ghost-w"
								>Call (603) 555-0199</a
							>
						</div>
						<div class="hero-stats">
							<div class="hero-stat">
								<b
									><span data-count="1200">0</span><span
										class="plus">+</span
									></b
								><span>Roofs Completed</span>
							</div>
							<div class="hero-stat">
								<b>4.9<span class="plus">★</span></b><span
									>Average Rating</span>
							</div>
							<div class="hero-stat">
								<b>25<span class="plus">yr</span></b><span
									>Workmanship Warranty</span>
							</div>
						</div>
					</div>

					<div class="hero-visual">
						<div class="hero-card">
							<img src="/image-1.png" alt="">
						</div>
						<div class="hero-float warranty">
							<div class="ic">
								<svg
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									><path
										d="M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-4z"
									></path><path d="M9 12l2 2 4-4"
									></path></svg>
							</div>
							<div>
								<b>25-Year Warranty</b><small
									>Written &amp; registered</small>
							</div>
						</div>
						<div class="hero-float review">
							<div class="stars">★★★★★</div>
							<p>
								"On time, spotless cleanup, and the roof looks
								incredible."
							</p>
							<small>Sample review — replace with real</small>
						</div>
					</div>
				</div>
			</section>

			<!-- Marquee trust bar -->
			<div class="marquee-wrap" aria-hidden="true">
				<div class="marquee" id="marquee">
					<span>Licensed &amp; Insured in NH</span><span
						>25-Year Workmanship Warranty</span
					><span>24/7 Storm Response</span><span
						>Free On-Site Estimates</span
					><span>Local NH Crews</span><span
						>Insurance Claims Assistance</span
					>
				</div>
			</div>

			<!-- Services -->
			<section class="section svc-section" id="services">
				<div class="container">
					<div class="sec-header">
						<span class="eyebrow">What We Do</span>
						<h2 class="sec-head">
							Every roofing service,<br /><span class="accent"
								>one accountable crew.</span>
						</h2>
						<p class="sec-sub">
							From a single missing shingle to a full commercial
							re-roof, the same licensed NH team handles it end to
							end — no subcontracted labor.
						</p>
					</div>
					<div class="svc-grid">
						<div class="svc-card feature reveal">
							<span class="svc-num">01</span>
							<div class="svc-icon">
								<svg
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="1.8"
									><path d="M3 11l9-7 9 7"></path><path
										d="M5 10v10h14V10"></path></svg>
							</div>
							<h3>Roof Replacement</h3>
							<p>
								Full tear-off and re-roof with
								manufacturer-certified materials, ice-and-water
								shield built for NH winters, and a 25-year
								written workmanship warranty registered at final
								walkthrough.
							</p>
							<a class="svc-arrow" href="/roof-replacement/"
								>Get a replacement quote</a
							>
						</div>
						<div class="svc-card feature reveal">
							<span class="svc-num">02</span>
							<div class="svc-icon">
								<svg
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="1.8"
									><path
										d="M13 2L4.5 12.5H11L9 22l8.5-10.5H12L13 2z"
									></path></svg>
							</div>
							<h3>Storm &amp; Emergency Response</h3>
							<p>
								Wind, hail, ice dams, and fallen-tree damage
								handled 24/7 across our NH service area —
								same-day tarping, full documentation for your
								insurer, and adjuster meetings on-site.
							</p>
							<a class="svc-arrow" href="/emergency-roofing/"
								>Call the emergency line</a
							>
						</div>
						<div class="svc-card reveal">
							<span class="svc-num">03</span>
							<div class="svc-icon">
								<svg
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="1.8"
									><path d="M14 6l4 4-9 9H5v-4l9-9z"
									></path><path d="M12 8l4 4"></path></svg>
							</div>
							<h3>Roof Repair</h3>
							<p>
								Leaks, flashing failures, and missing shingles
								diagnosed and fixed — usually within the week.
							</p>
							<a class="svc-arrow" href="/roof-repair/"
								>Book a repair</a
							>
						</div>
						<div class="svc-card reveal">
							<span class="svc-num">04</span>
							<div class="svc-icon">
								<svg
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="1.8"
									><circle cx="11" cy="11" r="7"
									></circle><path d="M21 21l-4.3-4.3"
									></path></svg>
							</div>
							<h3>Roof Inspection</h3>
							<p>
								Free, photo-documented inspections for home
								sales, insurance claims, or peace of mind.
							</p>
							<a class="svc-arrow" href="/roof-inspection/"
								>Schedule free inspection</a
							>
						</div>
						<div class="svc-card reveal">
							<span class="svc-num">05</span>
							<div class="svc-icon">
								<svg
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="1.8"
									><rect
										x="3"
										y="8"
										width="18"
										height="12"
										rx="1.5"></rect><path d="M3 12h18"
									></path></svg>
							</div>
							<h3>Commercial &amp; Flat Roofing</h3>
							<p>
								Low-slope and flat systems for retail, office,
								and multi-unit properties across the state.
							</p>
							<a class="svc-arrow" href="/commercial-roofing/"
								>Discuss your property</a
							>
						</div>
						<div class="svc-card reveal">
							<span class="svc-num">06</span>
							<div class="svc-icon">
								<svg
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="1.8"
									><path
										d="M4 6l8-3 8 3M4 6v12l8 3 8-3V6M4 6l8 3 8-3M12 9v12"
									></path></svg>
							</div>
							<h3>Metal Roofing</h3>
							<p>
								Standing-seam metal that sheds snow, outlasts
								asphalt, and looks sharp doing it.
							</p>
							<a class="svc-arrow" href="/metal-roofing/"
								>Explore metal options</a
							>
						</div>
						<div class="svc-card reveal">
							<span class="svc-num">07</span>
							<div class="svc-icon">
								<svg
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="1.8"
									><path
										d="M3 5h18v4H3zM5 9v10M19 9v10M5 15h14"
									></path></svg>
							</div>
							<h3>Gutters &amp; Siding</h3>
							<p>
								Seamless gutters, gutter repair, and siding work
								that protects the whole exterior.
							</p>
							<a class="svc-arrow" href="/gutter-installation/"
								>Get an exterior quote</a
							>
						</div>
						<div class="svc-card reveal">
							<span class="svc-num">08</span>
							<div class="svc-icon">
								<svg
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="1.8"
									><path
										d="M9 12h6M9 16h6M13 2H7a2 2 0 00-2 2v16a2 2 0 002 2h10a2 2 0 002-2V8l-6-6z"
									></path><path d="M13 2v6h6"></path></svg>
							</div>
							<h3>Insurance Claims Help</h3>
							<p>
								We document damage, meet your adjuster on-site,
								and walk the paperwork through with you.
							</p>
							<a
								class="svc-arrow"
								href="/insurance-claims-assistance/"
								>Start a claim</a
							>
						</div>
					</div>
				</div>
			</section>

			<!-- Why -->
			<section class="section" id="why">
				<div class="container why-wrap">
					<div class="why-visual reveal">
						<div class="frame">
							<img src="/image-2.png" alt="">
						</div>
						<div class="why-chip">
							<b>1,200+</b><small>NH roofs completed</small>
						</div>
					</div>
					<div>
						<span class="eyebrow">Why Vincenzo's</span>
						<h2 class="sec-head">
							Craftsmanship you can<br /><span class="accent"
								>hold us to in writing.</span>
						</h2>
						<div class="why-list">
							<div class="why-item reveal">
								<div class="why-icon">
									<svg
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="1.9"
										><path
											d="M9 12h6M9 16h4M13 2H7a2 2 0 00-2 2v16a2 2 0 002 2h10a2 2 0 002-2V8l-6-6z"
										></path></svg>
								</div>
								<div>
									<h4>Itemized written estimates</h4><p>
										Materials, labor, and timeline broken
										out line by line — no surprise charges
										at the end.
									</p>
								</div>
							</div>
							<div class="why-item reveal">
								<div class="why-icon">
									<svg
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="1.9"
										><path
											d="M12 21c4-3 7-6.5 7-11a7 7 0 10-14 0c0 4.5 3 8 7 11z"
										></path><circle cx="12" cy="10" r="2.4"
										></circle></svg>
								</div>
								<div>
									<h4>Local NH crews, no subs</h4><p>
										The crew that quotes your roof is the
										crew that installs it. Based here,
										working here daily.
									</p>
								</div>
							</div>
							<div class="why-item reveal">
								<div class="why-icon">
									<svg
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="1.9"
										><path
											d="M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-4z"
										></path><path d="M9 12l2 2 4-4"
										></path></svg>
								</div>
								<div>
									<h4>25-year workmanship warranty</h4><p>
										Separate from the manufacturer's
										material warranty, in writing,
										registered before we leave.
									</p>
								</div>
							</div>
							<div class="why-item reveal">
								<div class="why-icon">
									<svg
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="1.9"
										><circle cx="12" cy="12" r="9"
										></circle><path d="M12 7v5l3.5 2"
										></path></svg>
								</div>
								<div>
									<h4>Daily magnetic cleanup</h4><p>
										Nail sweeps and debris removal at the
										end of every work day — not just the
										last one.
									</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Process -->
			<section class="section process" id="process">
				<div class="container">
					<div class="sec-header">
						<span class="eyebrow">How It Works</span>
						<h2 class="sec-head">
							First call to final walkthrough,<br />in four steps.
						</h2>
					</div>
					<div class="process-grid">
						<div class="p-step reveal">
							<span class="p-num">Step 01</span><h4>
								Free Inspection
							</h4><p>
								We assess the roof, photograph problem areas,
								and give you an honest read — no cost, no
								obligation.
							</p>
						</div>
						<div class="p-step reveal">
							<span class="p-num">Step 02</span><h4>
								Written Estimate
							</h4><p>
								A detailed, itemized quote covering materials,
								labor, and a realistic timeline. Valid in
								writing.
							</p>
						</div>
						<div class="p-step reveal">
							<span class="p-num">Step 03</span><h4>
								Scheduled Install
							</h4><p>
								Tear-off, install, and daily cleanup handled by
								our own crew, with progress updates throughout.
							</p>
						</div>
						<div class="p-step reveal">
							<span class="p-num">Step 04</span><h4>
								Final Walkthrough
							</h4><p>
								We inspect the finished roof with you and
								register your 25-year workmanship warranty on
								the spot.
							</p>
						</div>
					</div>
				</div>
			</section>

			<!-- Gallery -->
			<section class="section" id="gallery">
				<div class="container">
					<div class="sec-header">
						<span class="eyebrow">Recent Work</span>
						<h2 class="sec-head">
							Real roofs, <span class="accent"
								>across the state.</span>
						</h2>
					</div>
					<div class="ba-grid">
						<div class="ba-card reveal">
							<div class="ba-media">
								<img src="/image-5.png" alt="">
								<!-- <span class="ba-tag">Before → After</span> -->
							</div>
							<div class="ba-body">
								<h4>Asphalt Shingle Replacement</h4><p>
									Manchester, NH — full tear-off and re-roof
								</p>
							</div>
						</div>
						<div class="ba-card reveal">
							<div class="ba-media">
								<img src="/image-4.png" alt="">
								<!-- <span class="ba-tag">Before → After</span> -->
							</div>
							<div class="ba-body">
								<h4>Storm Damage Restoration</h4><p>
									Nashua, NH — wind damage, insurance-assisted
								</p>
							</div>
						</div>
						<div class="ba-card reveal">
							<div class="ba-media">
								<img src="/image-3.png" alt="">
								<!-- <span class="ba-tag">Before → After</span> -->
							</div>
							<div class="ba-body">
								<h4>Standing-Seam Metal Roof</h4><p>
									Portsmouth, NH — commercial install
								</p>
							</div>
						</div>
					</div>
					<p class="note">
						Illustrative placeholders — swap in real project
						photography before launch.
					</p>
				</div>
			</section>

			<!-- Testimonials -->
			 <Testimonials/>
			

			
			<section class="emergency">
				<div class="container">
					<div>
						<span class="badge247"
							><span class="pulse" style="background:#fff;"
							></span>24/7 Response</span
						>
						<h2>Active leak or storm damage right now?</h2>
						<p>
							Same-day emergency tarping anywhere in our New
							Hampshire service area. One call, and a crew is on
							the way.
						</p>
					</div>
					<a href="tel:+16035550199" class="btn btn-white"
						>Call the Emergency Line</a
					>
				</div>
			</section>

			<!-- Areas -->
			<section class="section" id="areas">
				<div class="container areas-wrap">
					<div>
						<span class="eyebrow">Service Areas</span>
						<h2 class="sec-head">
							Every corner of<br /><span class="accent"
								>New Hampshire.</span>
						</h2>
						<p class="sec-sub">
							From Manchester to the Seacoast, our crews are on
							the road across the state daily. Don't see your
							town? We're probably still nearby — ask.
						</p>
						<div class="area-chips">
							<a
								class="area-chip"
								href="/service-areas/manchester-nh/"
								>Manchester</a
							><a
								class="area-chip"
								href="/service-areas/nashua-nh/">Nashua</a
							><a
								class="area-chip"
								href="/service-areas/concord-nh/">Concord</a
							>
							<a
								class="area-chip"
								href="/service-areas/portsmouth-nh/"
								>Portsmouth</a
							><a
								class="area-chip"
								href="/service-areas/dover-nh/">Dover</a
							><a
								class="area-chip"
								href="/service-areas/rochester-nh/">Rochester</a
							>
							<a class="area-chip" href="/service-areas/keene-nh/"
								>Keene</a
							><a
								class="area-chip"
								href="/service-areas/salem-nh/">Salem</a
							><a
								class="area-chip"
								href="/service-areas/derry-nh/">Derry</a
							>
							<a
								class="area-chip"
								href="/service-areas/londonderry-nh/"
								>Londonderry</a
							><a
								class="area-chip"
								href="/service-areas/hudson-nh/">Hudson</a
							><a
								class="area-chip"
								href="/service-areas/bedford-nh/">Bedford</a
							>
							<a
								class="area-chip"
								href="/service-areas/merrimack-nh/">Merrimack</a
							><a
								class="area-chip"
								href="/service-areas/exeter-nh/">Exeter</a
							><a
								class="area-chip"
								href="/service-areas/hampton-nh/">Hampton</a
							>
						</div>
					</div>
					<div class="map-frame reveal">
						<svg
							viewBox="0 0 520 430"
							xmlns="http://www.w3.org/2000/svg"
						>
							<rect width="520" height="430" fill="#071F45"
							></rect>
							<path
								d="M160 30 L355 62 L335 168 L378 232 L346 360 L188 392 L126 274 L94 126 Z"
								fill="#0E2B5B"
								stroke="#0D47A1"
								stroke-width="2.5"></path>
							<g fill="#4A7FD4"
								><circle cx="210" cy="190" r="6"
								></circle><circle cx="252" cy="232" r="6"
								></circle><circle cx="190" cy="105" r="6"
								></circle><circle cx="272" cy="315" r="6"
								></circle><circle cx="318" cy="210" r="6"
								></circle></g
							>
							<g
								fill="none"
								stroke="#4A7FD4"
								stroke-opacity="0.35"
								stroke-width="1.4"
							>
								<circle cx="210" cy="190" r="14"
								></circle><circle cx="252" cy="232" r="14"
								></circle><circle cx="190" cy="105" r="14"
								></circle><circle cx="272" cy="315" r="14"
								></circle><circle cx="318" cy="210" r="14"
								></circle>
							</g>
							<text
								x="260"
								y="416"
								fill="#7A8FB4"
								font-family="Montserrat,sans-serif"
								font-weight="600"
								font-size="11"
								text-anchor="middle"
								letter-spacing="2"
								>SERVING ALL OF NEW HAMPSHIRE</text
							>
						</svg>
					</div>
				</div>
			</section>

			<!-- Financing -->
			<section class="section fin">
				<div class="container">
					<div class="sec-header">
						<span class="eyebrow">Financing</span>
						<h2 class="sec-head">
							A new roof, <span class="accent"
								>on your terms.</span>
						</h2>
					</div>
					<div class="fin-grid">
						<div class="fin-card reveal">
							<span class="fin-tag">Plan A</span><h4>
								0% Interest, 12 Months
							</h4><p>
								Short-term financing for qualified homeowners
								with no interest if paid within a year.
							</p>
						</div>
						<div class="fin-card pop reveal">
							<span class="fin-tag">Most Popular</span><h4>
								Low Monthly Payments
							</h4><p>
								Extended terms that keep larger projects
								manageable — spread the cost, keep the warranty.
							</p>
						</div>
						<div class="fin-card reveal">
							<span class="fin-tag">Insurance</span><h4>
								Claims-Assisted Roofing
