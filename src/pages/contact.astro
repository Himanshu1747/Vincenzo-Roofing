---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Testimonials from "../components/Testimonials.astro";
import Faqcompo from "../components/Faqcompo.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
   
    </head>
    <body>
        <Header />

        <main id="top">
            <section class="page-hero">
                <div class="container">
                    <div class="breadcrumb">
                        <a href="../index.html">Home</a>
                        <span>/</span>
                        <span style="color:#fff;">Contact</span>
                    </div>
                    <h1 class="fade-up">
                        Tell us about <em
                            style="font-style:normal;color:#9CC0FF;"
                            >your roof.</em>
                    </h1>
                    <p class="lede-page fade-up">
                        Fill out the form below or call the office directly. We
                        typically reply within one business hour, 7am–6pm, and
                        the emergency line is answered 24/7.
                    </p>
                </div>
            </section>

            <section class="section" id="contact">
                <div class="container">
                    <div class="contact-wrap">
                        <div class="contact-form">
                            <form onsubmit="return false;">
                                <div class="form-row">
                                    <div class="form-field">
                                        <label for="fname">First Name</label
                                        ><input
                                            id="fname"
                                            type="text"
                                            placeholder="Jane"
                                            autocomplete="given-name"
                                            required
                                        />
                                    </div>
                                    <div class="form-field">
                                        <label for="lname">Last Name</label
                                        ><input
                                            id="lname"
                                            type="text"
                                            placeholder="Doe"
                                            autocomplete="family-name"
                                            required
                                        />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-field">
                                        <label for="phone">Phone</label><input
                                            id="phone"
                                            type="tel"
                                            placeholder="(603) 555-0100"
                                            autocomplete="tel"
                                            required
                                        />
                                    </div>
                                    <div class="form-field">
                                        <label for="email">Email</label><input
                                            id="email"
                                            type="email"
                                            placeholder="jane@example.com"
                                            autocomplete="email"
                                            required
                                        />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-field full">
                                        <label for="address"
                                            >Property Address</label
                                        ><input
                                            id="address"
                                            type="text"
                                            placeholder="123 Main St, Manchester, NH"
                                            autocomplete="street-address"
                                        />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-field full">
                                        <label for="service"
                                            >Service Needed</label
                                        >
                                        <select id="service">
                                            <option>Roof Replacement</option
                                            ><option>Roof Repair</option><option
                                                >Roof Inspection</option
                                            >
                                            <option>Storm Damage</option><option
                                                >Commercial Roofing</option
                                            ><option>Gutters / Siding</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-field full">
                                        <label for="msg">Details</label
                                        ><textarea
                                            id="msg"
                                            rows="4"
                                            placeholder="Tell us about your roof, timeline, or concerns."
                                        ></textarea>
                                    </div>
                                </div>
                                <button
                                    type="submit"
                                    class="btn btn-blue"
                                    style="width:100%;"
                                    >Request Free Estimate</button
                                >
                                <p
                                    style="font-size:12px;color:var(--grey-light);margin-top:14px;text-align:center;"
                                >
                                    Typically replies within one business hour,
                                    7am–6pm.
                                </p>
                            </form>
                        </div>
                        <div class="contact-side">
                            <div class="info-card">
                                <h3>Vincenzo's Roofing LLC</h3>
                                <div class="info-row">
                                    <span class="ic"
                                        ><svg
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="1.9"
                                            ><path
                                                d="M22 16.9v3a2 2 0 01-2.2 2 19.8 19.8 0 01-8.6-3 19.5 19.5 0 01-6-6 19.8 19.8 0 01-3-8.7A2 2 0 014.1 2h3a2 2 0 012 1.7c.1.9.3 1.8.6 2.7a2 2 0 01-.5 2.1L8 9.9a16 16 0 006 6l1.4-1.4a2 2 0 012.1-.5c.9.3 1.8.5 2.7.6a2 2 0 011.8 2.3z"
                                            ></path></svg
                                        ></span
                                    ><a href="tel:+16035550199"
                                        >(603) 555-0199</a>
                                </div>
                                <div class="info-row">
                                    <span class="ic"
                                        ><svg
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="1.9"
                                            ><path d="M4 4h16v16H4z"
                                            ></path><path d="M4 6l8 7 8-7"
                                            ></path></svg
                                        ></span
                                    ><a href="mailto:info@vincenzosroofing.com"
                                        >info@vincenzosroofing.com</a>
                                </div>
                                <div class="info-row">
                                    <span class="ic"
                                        ><svg
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="1.9"
                                            ><path
                                                d="M12 21c4-3 7-6.5 7-11a7 7 0 10-14 0c0 4.5 3 8 7 11z"
                                            ></path><circle
                                                cx="12"
                                                cy="10"
                                                r="2.4"></circle></svg
                                        ></span
                                    ><span>Serving all of New Hampshire</span>
                                </div>
                                <div class="info-row">
                                    <span class="ic"
                                        ><svg
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="1.9"
                                            ><circle cx="12" cy="12" r="9"
                                            ></circle><path d="M12 7v5l3.5 2"
                                            ></path></svg
                                        ></span
                                    ><span
                                        >Mon–Fri 7am–6pm · 24/7 Emergency</span>
                                </div>
                            </div>
                            <div class="map-frame">
                                <svg
                                    viewBox="0 0 520 250"
                                    xmlns="http://www.w3.org/2000/svg"
                                >
                                    <rect
                                        width="520"
                                        height="250"
                                        fill="#071F45"></rect>
                                    <path
                                        d="M170 18 L350 40 L332 118 L370 158 L342 232 L196 244 L138 170 L108 78 Z"
                                        fill="#0E2B5B"
                                        stroke="#0D47A1"
                                        stroke-width="2.5"></path>
                                    <circle
                                        cx="250"
                                        cy="130"
                                        r="7"
                                        fill="#4A7FD4"></circle>
                                    <circle
                                        cx="250"
                                        cy="130"
                                        r="16"
                                        fill="none"
                                        stroke="#4A7FD4"
                                        stroke-opacity="0.35"
                                        stroke-width="1.5"></circle>
                                </svg>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Emergency -->
            <section class="emergency">
                <div class="container">
                    <div>
                        <span class="badge247"
                            ><span class="pulse" style="background:#fff;"
                            ></span>24/7 Response</span
                        >
                        <h2>Active leak or storm damage right now?</h2>
                        <p>
                            Skip the form — same-day emergency tarping anywhere
                            in our New Hampshire service area. One call, and a
                            crew is on the way.
                        </p>
                    </div>
                    <a href="tel:+16035550199" class="btn btn-white"
                        >Call the Emergency Line</a
                    >
                </div>
            </section>
        </main>

        <Footer />
    </body>
</html>
