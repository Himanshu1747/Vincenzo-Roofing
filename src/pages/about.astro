---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Testimonials from "../components/Testimonials.astro";
import Faqcompo from "../components/Faqcompo.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
		/>
	</head>
	<body>
		<Header />
		
<main id="top">

  <!-- Page hero -->
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="../index.html">Home</a> <span>/</span> <span style="color:#fff;">About</span></div>
      <h1 class="fade-up">A family-run NH roofing crew, <em style="font-style:normal;color:#9CC0FF;">on your street already.</em></h1>
      <p class="lede-page fade-up">Vincenzo's Roofing has spent over a decade putting local crews — not subcontractors — on New Hampshire roofs, backed by written warranties and straight answers.</p>
    </div>
  </section>

  <!-- Story -->
  <section class="section">
    <div class="container story-wrap">
      <div class="story-media">
        <div class="photo-frame ratio-4-3">
          <img src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=800&q=80"
               onerror="imgFallback(this,'about-team')"
               alt="Vincenzo's Roofing team reviewing a project plan on-site" loading="lazy">
        </div>
        <div class="badge-founded"><b>2013</b><span>Founded in NH</span></div>
      </div>
      <div class="story-copy">
        <span class="eyebrow">Our Story</span>
        <h2 class="sec-head">Started with one ladder<br><span class="accent">and a written promise.</span></h2>
        <p>Vincenzo's Roofing LLC began as a two-person crew doing repair work around Manchester. The idea was simple: quote it honestly, show up when you say you will, and put the warranty in writing before you leave the driveway.</p>
        <p>Thirteen years later, that's still the whole business model. We've grown to a full residential and commercial roofing company serving every corner of New Hampshire, but every job is still run by the same in-house crews — no subcontracted labor, no surprise line items.</p>
        <p>Today Vincenzo's Roofing has completed more than 1,200 roofs across the state, from single-shingle repairs to full commercial re-roofs, and we still answer the emergency line ourselves, 24/7.</p>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="stat-strip">
         <div class="stat-box reveal"><b>1200+</b><span>Roofs Completed</span></div>
         <div class="stat-box reveal"><b>25</b><span>Years in Business</span></div>
        <div class="stat-box reveal"><b>4.9★</b><span>Average Rating</span></div>
       <div class="stat-box reveal"><b>5</b><span>Year Workmanship Warranty</span></div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section">
    <div class="container">
      <div class="sec-header">
        <span class="eyebrow">What We Stand For</span>
        <h2 class="sec-head">Four things we<br><span class="accent">won't compromise on.</span></h2>
      </div>
      <div class="values-grid">
        <div class="value-card reveal">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M9 12h6M9 16h4M13 2H7a2 2 0 00-2 2v16a2 2 0 002 2h10a2 2 0 002-2V8l-6-6z"/></svg></div>
          <h4>Honest, itemized quotes</h4>
          <p>Every estimate breaks out materials, labor, and timeline — no vague lump sums.</p>
        </div>
        <div class="value-card reveal">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M12 21c4-3 7-6.5 7-11a7 7 0 10-14 0c0 4.5 3 8 7 11z"/><circle cx="12" cy="10" r="2.4"/></svg></div>
          <h4>Local, in-house crews</h4>
          <p>The people who quote your roof are the people who install it. No subcontracting.</p>
        </div>
        <div class="value-card reveal">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-4z"/><path d="M9 12l2 2 4-4"/></svg></div>
          <h4>Warranties in writing</h4>
          <p>A 25-year workmanship warranty, registered before we ever leave the job site.</p>
        </div>
        <div class="value-card reveal">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2"/></svg></div>
          <h4>Show up, clean up</h4>
          <p>On-time crews and daily magnetic nail sweeps — not just on the last day of the job.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="section">
    <div class="container">
      <div class="sec-header">
        <span class="eyebrow">Meet The Crew</span>
        <h2 class="sec-head">The people who'll be<br><span class="accent">on your roof.</span></h2>
        <p class="sec-sub">A small leadership team backed by full-time, in-house installation crews across New Hampshire.</p>
      </div>
      <div class="team-grid">
        <div class="team-card reveal">
          <div class="photo-frame ratio-1-1">
            <img src="https://images.unsplash.com/photo-1556157382-97eda2d62296?auto=format&fit=crop&w=500&q=80" onerror="imgFallback(this,'team1')" alt="Portrait of Vincenzo, founder and owner" loading="lazy">
          </div>
          <h4>Vincenzo Marino</h4>
          <span class="role">Founder &amp; Owner</span>
          <p>Started the company in 2013 and still walks final inspections on every large project.</p>
        </div>
        <div class="team-card reveal">
          <div class="photo-frame ratio-1-1">
            <img src="https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?auto=format&fit=crop&w=500&q=80" onerror="imgFallback(this,'team2')" alt="Portrait of operations manager" loading="lazy">
          </div>
          <h4>Sarah Coughlin</h4>
          <span class="role">Operations Manager</span>
          <p>Keeps every crew scheduled, every estimate written, and every customer updated.</p>
        </div>
        <div class="team-card reveal">
          <div class="photo-frame ratio-1-1">
            <img src="https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?auto=format&fit=crop&w=500&q=80" onerror="imgFallback(this,'team3')" alt="Portrait of lead installation foreman" loading="lazy">
          </div>
          <h4>Marcus Dubois</h4>
          <span class="role">Lead Foreman</span>
          <p>Runs the largest install crew and trains every new hire on our safety and cleanup standards.</p>
        </div>
        <div class="team-card reveal">
          <div class="photo-frame ratio-1-1">
            <img src="https://images.unsplash.com/photo-1580489944761-15a19d654956?auto=format&fit=crop&w=500&q=80" onerror="imgFallback(this,'team4')" alt="Portrait of insurance claims specialist" loading="lazy">
          </div>
          <h4>Renee Ostrowski</h4>
          <span class="role">Insurance Claims Specialist</span>
          <p>Meets adjusters on-site and handles the paperwork so storm claims move faster.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="section" style="background:var(--off);">
    <div class="container">
      <div class="sec-header">
        <span class="eyebrow">Milestones</span>
        <h2 class="sec-head">Thirteen years,<br><span class="accent">one town at a time.</span></h2>
      </div>
      <div class="timeline">
        <div class="timeline-item reveal">
          <b>2013</b>
          <h4>Vincenzo's Roofing founded</h4>
          <p>Started as a two-person repair crew serving Manchester and surrounding towns.</p>
        </div>
        <div class="timeline-item reveal">
          <b>2016</b>
          <h4>First commercial contracts</h4>
          <p>Expanded into low-slope and flat commercial roofing for retail and office properties.</p>
        </div>
        <div class="timeline-item reveal">
          <b>2019</b>
          <h4>Statewide storm response team launched</h4>
          <p>Built a dedicated 24/7 emergency crew and insurance claims support after a major NH storm season.</p>
        </div>
        <div class="timeline-item reveal">
          <b>2023</b>
          <h4>1,000th roof completed</h4>
          <p>Crossed 1,000 residential and commercial roofs completed across New Hampshire.</p>
        </div>
        <div class="timeline-item reveal">
          <b>2026</b>
          <h4>Still local, still in-house</h4>
          <p>Now serving 15+ NH communities with the same no-subcontractor promise we started with.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section class="cta-band">
    <div class="cta-inner">
      <h2>Want to talk to the crew <em>before you book?</em></h2>
      <div class="btns">
        <a href="contact.html" class="btn btn-blue">Get Your Free Estimate</a>
        <a href="tel:+16035550199" class="btn btn-ghost-w">Call Now</a>
      </div>
    </div>
  </section>

</main>

		<Footer />
	</body>
</html>
